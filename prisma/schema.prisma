// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//　メモ）装飾（ ?　）がない行は必須（null不可になる）
// @map→ Prisma ⇄ DB の変換のためのもの。フロントでの名称は自由。API側でPrisma表記に直せばOK
//@default(cuid()) →APIでそのモデル内のcreateをするたびに、idを自動生成するという意味

generator client { //（生成の指示）「Prisma Client（JS/TS用）を生成するプログラム（prisma-client-js）を使ってね」
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {   //（接続先の指定）「接続先のDBは PostgreSQL だよ」※Prisma が PostgreSQL向けのSQL/接続方法で話す必要がある
  provider = "postgresql"
  //Prisma7でここにurlは廃止
}


//modelが（箱の設計図）

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum RecipeCategory {
  MAIN        // 主菜
  SIDE        // 副菜
  UNCLASSIFIED // 未分類
}

enum RecipeSourceType {
  MANUAL  // 手入力
  TEXT    // テキスト（例：誰かにもらった文章、メモから）
  URL     // URLから
}

//献立分類
enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}



model User {
  id           String @id @db.Uuid//Supabase のUUIDを使用するため @default(uuid()) 削除
  nickname     String
  email        String      @unique
  authProvider AuthProvider @map("auth_provider")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now())

  // relations
  recipes Recipe[]

  //お気に入りテーブルとのリレーション
  userRecipeStatus UserRecipeStatus[]

  @@map("users")
}

model Ingredient {
  id             String @id @default(uuid()) @db.Uuid
  name           String
  normalizedName String   @map("normalized_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relations
  recipeIngredients RecipeIngredient[]

  @@map("ingredients")
}

model Recipe {
  id           String @id @default(uuid()) @db.Uuid //主キーのこと
  ownerUserId  String @db.Uuid @map("owner_user_id")//@map→Prizma上ではownerUserIdとして扱うが、DBのカラム名はowner_user_idにする。参照している値はuserのid
  title        String
  category     RecipeCategory   @default(UNCLASSIFIED)//実質カテゴリも任意だが、未分類がデフォルトとなるため？は不要
  sourceType   RecipeSourceType @map("source_type")   //登録方式
  sourceUrl    String?          @map("source_url") //URLで登録ならその元のURL
  sourceText   String?          @map("source_text")
  thumbnailUrl String?          @map("thumbnail_url")
  memo         String?
  servings     Int  //何人分か

  createdAt DateTime @default(now()) @map("created_at")//now()→デフォルトがnowってこと。作成時刻を自動で入れる
  updatedAt DateTime @updatedAt @map("last_updated_at")//updateAtは更新時に自動更新（自動で今の時刻になる）ってこと

  ownerUser User @relation(fields: [ownerUserId], references: [id]) 
  //例）Aさんがレシピを保存したら、このリレーションを使用することでuserテーブルのidを引っ張ってきて、DBの「owner_user_id」に保存できるという意味。

  recipeIngredients RecipeIngredient[]
  recipeSteps       RecipeStep[]

  //お気に入りテーブルとのリレーション
  userRecipeStatus UserRecipeStatus[] 

  //献立カレンダーとのリレーション
  menuRecipes MenuRecipe[]

  @@map("recipes")
}


model RecipeIngredient {
  id           String   @id @default(uuid()) @db.Uuid
  recipeId     String   @db.Uuid
  ingredientId String   @db.Uuid

  quantityText Float    @map("quantity_text")//材料の量カラム
  unitId       String   @db.Uuid//材料の単位カラム
  isSeasoning  Boolean  @default(false) @map("is_seasoning")
  sortOrder    Int      @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  recipe     Recipe     @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  unit Unit @relation(fields:[unitId], references:[id])

  @@map("recipe_ingredients")
}

model RecipeStep {
  id               String   @id @default(uuid()) @db.Uuid
  recipeId         String   @db.Uuid
  stepNumber       Int      @map("step_number")
  instructionText  String   @map("instruction_text")
  sortOrder        Int      @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  recipe Recipe @relation(fields: [recipeId], references: [id]) 

  @@map("recipe_steps")
}

//材料単位テーブル
model Unit {
  id String @id @default(uuid()) @db.Uuid
  name String  // 本 個 g ml
  recipeIngredients RecipeIngredient[]
}

//お気に入りテーブル

model UserRecipeStatus {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  recipeId  String   @db.Uuid

  isFavorite       Boolean @default(false)//お気に入り
  hasCooked        Boolean @default(false)//作ったことある

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId]) // userId と recipeId の組み合わせは1つしか存在しない
  @@map("user_recipe_status")
}

//その日の献立を渡すテーブル
model Menu {
  id        String       @id @default(uuid()) @db.Uuid//献立自体のid
  userId    String       @db.Uuid//この献立が誰のものか
  date      String//UTCでズレが発生してしまうため、献立は文字列で日付までで管理
  createdAt DateTime     @default(now())//献立がいつ作られたか

  menuRecipes MenuRecipe[]//この献立に属するレシピ一覧（フロントで取得した時、ここに献立レシピが格納されている）

  @@unique([userId, date])//これでユーザー + 日付の献立は 1つだけになります
}

//献立レシピテーブル（献立に関するレシピ情報）
model MenuRecipe {//１日の中の1つのレシピ
  id        String   @id @default(uuid()) @db.Uuid//MenuRecipe自体のID(MenuRecipeを個別で操作するときに使う)
  menuId    String   @db.Uuid//どの献立に属するか（このMenuRecipeが属する献立(Menu)のID）
  recipeId  String   @db.Uuid//どのレシピか（実際に登録されたレシピのID（Recipeテーブルのid））
  mealType  MealType//朝昼晩
  position  Int?//mealTypeの中での並び順
  createdAt DateTime @default(now())

  //onDeleateはMenuが削除されたらMenuRecipeも削除
  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)//MenuRecipe は Menu に属する
  recipe Recipe @relation(fields: [recipeId], references: [id])//献立に入ってるレシピ

  @@index([menuId])//検索高速化
}

//買い物リスト専用テーブル
model ShoppingItem {
  id           String   @id @default(uuid())
  userId       String
  ingredientId String?
  name         String
  quantityText Float?
  unitName     String?
  checked      Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}