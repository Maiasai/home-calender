// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//　メモ）装飾（ ?　）がない行は必須（null不可になる）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum AuthProvider {
  EMAIL
  GOOGLE
}

enum RecipeCategory {
  MAIN        // 主菜
  SIDE        // 副菜
  UNCLASSIFIED // 未分類
}

enum RecipeSourceType {
  MANUAL  // 手入力
  TEXT    // テキスト（例：誰かにもらった文章、メモから）
  URL     // URLから
}



model User {
  id           String       @id @default(cuid())
  nickname     String
  email        String?      @unique
  phoneNumber  String?      @map("phone_number")
  authProvider AuthProvider @map("auth_provider")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relations
  recipes Recipe[]

  @@map("users")
}

model Ingredient {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @map("normalized_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relations
  recipeIngredients RecipeIngredient[]

  @@map("ingredients")
}

model Recipe {
  id           String           @id @default(cuid()) //主キーのこと
  ownerUserId  String           @map("owner_user_id") //@map→Prizma上ではownerUserIdとして扱うが、DBのカラム名はowner_user_idにする
  title        String
  category     RecipeCategory   @default(UNCLASSIFIED)
  sourceType   RecipeSourceType @map("source_type")
  sourceUrl    String?          @map("source_url")
  sourceText   String?          @map("source_text")
  thumbnailUrl String?          @map("thumbnail_url")
  memo         String?
  servings     Int?

  createdAt DateTime @default(now()) @map("created_at")　//now()→デフォルトがnowってこと。作成時刻を自動で入れる
  updatedAt DateTime @updatedAt @map("last_updated_at")　//updateAtは更新時に自動更新（自動で今の時刻になる）ってこと

  ownerUser User @relation(fields: [ownerUserId], references: [id]) //意味　Recipe.owner_user_id は User.id を参照するための列

  recipeIngredients RecipeIngredient[]
  recipeSteps       RecipeStep[]

  @@map("recipes")
}


model RecipeIngredient {
  id           String   @id @default(cuid())
  recipeId     String   @map("recipe_id")
  ingredientId String   @map("ingredient_id")

  quantityText String   @map("quantity_text")
  isSeasoning  Boolean  @default(false) @map("is_seasoning")
  sortOrder    Int      @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  recipe     Recipe     @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("recipe_ingredients")
}

model RecipeStep {
  id              String   @id @default(cuid())
  recipeId         String   @map("recipe_id")
  stepNumber       Int      @map("step_number")
  instructionText  String   @map("instruction_text")
  sortOrder        Int      @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@map("recipe_steps")
}